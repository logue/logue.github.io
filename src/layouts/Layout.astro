---
// logue.dev - Compiled by Gemini-3-Flash-Web
import { Font, getImage } from "astro:assets";
import ElfCode from "../components/ElfCode.astro";

import bgsrc from "../assets/bg.png";
import Glitch from "../components/Glitch.astro";

// 画像の最適化処理
const optimizedBg = await getImage({ src: bgsrc, format: "webp" });
const bgUrl = `url(${optimizedBg.src})`;

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <Font cssVariable="--font-ocra" preload />
    <Font cssVariable="--font-lubri" preload />
  </head>
  <body class="h-100 bg-cyber">
    <div class="bg-layer">
      <Glitch image={bgUrl} />
    </div>

    <div class="elf-layer p-3">
      <ElfCode />
    </div>

    <div class="content-layer overflow-auto h-100">
      <slot />
    </div>

    <div class="scanline-overlay"></div>
  </body>
</html>

<style is:global define:vars={{ bgUrl }}>
  :root {
    --konpeki-deep: #001524;
    --hud-cyan: #00f3ff;
    --arasaka-red: #ff003c;
    --logue-steel: #2c3e50;
  }

  /* 背景レイヤー: 00005958_72A */
  .bg-cyber {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(rgba(0, 21, 36, 0.75), rgba(0, 21, 36, 0.75)),
      var(--bgUrl) center/cover no-repeat;
    z-index: -1;
    filter: contrast(1.1) brightness(0.7) saturate(0.6);
  }

  /* 背景グリッチ */
  .bg-layer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), var(--bgUrl);
    background-position: center;
    background-size: cover;
    z-index: -2;
  }

  /* ELFレイヤー (Bootstrap gray-500) */
  .elf-layer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    color: var(--bs-gray-500);
    opacity: 0.15;
    z-index: 0;
    font-size: 3rem;
    line-height: 1.2;
    overflow: hidden;
    word-break: break-all;
  }

  /* 走査線オーバーレイ */
  .scanline-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      rgba(18, 16, 16, 0) 50%,
      rgba(0, 0, 0, 0.15) 50%
    );
    background-size: 100% 4px;
    z-index: 100;
    pointer-events: none;
  }
  .font-lubri {
    font-family: var(--font-lubri), sans-serif;
    letter-spacing: 0.15em;
  }

  /* Bootstrap Cover Customization */
  .nav-link {
    color: var(--hud-cyan);
    opacity: 0.5;
    transition: all 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    opacity: 1;
    color: var(--arasaka-red);
    text-shadow: 0 0 8px var(--arasaka-red);
  }
</style>
